# =============================================================================
# Saleor Platform — Production Environment Variables
# =============================================================================
# Copy this file to .env and fill in all required values before deploying.
# Variables marked [REQUIRED] must be set. Others have sensible defaults.
#
# SECURITY: Never commit the actual .env file to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# PostgreSQL Database
# -----------------------------------------------------------------------------
POSTGRES_USER=saleor                          # Database username
POSTGRES_PASSWORD=                            # [REQUIRED] Strong password (min 32 chars)
POSTGRES_DB=saleor                            # Database name

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------
REDIS_PASSWORD=                               # [REQUIRED] Strong password (min 32 chars)

# -----------------------------------------------------------------------------
# Django / Saleor API
# -----------------------------------------------------------------------------
SECRET_KEY=                                   # [REQUIRED] Django secret key (run: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())")
DEBUG=False                                   # Always False in production
ALLOWED_HOSTS=api.yourdomain.com              # [REQUIRED] Comma-separated list of allowed hostnames
ALLOWED_CLIENT_HOSTS=shop.yourdomain.com,dashboard.yourdomain.com  # [REQUIRED] Frontend domains

# Public URL (how the API is accessed externally)
PUBLIC_URL=https://api.yourdomain.com

# Security cookies
SESSION_COOKIE_SECURE=True
CSRF_COOKIE_SECURE=True
SECURE_SSL_REDIRECT=False                     # Let Nginx handle SSL redirect

# Disable GraphQL Playground in production
GRAPHQL_PLAYGROUND_ENABLED=False

# Database connection settings
DB_CONN_MAX_AGE=60                            # Connection pooling (seconds)

# Timezone
TIME_ZONE=UTC

# -----------------------------------------------------------------------------
# Email (SMTP)
# -----------------------------------------------------------------------------
# Format: smtp://user:password@host:port/?tls=True
# Examples:
#   SendGrid:  smtp://apikey:SG.xxx@smtp.sendgrid.net:587/?tls=True
#   AWS SES:   smtp://AKID:SECRET@email-smtp.us-east-1.amazonaws.com:587/?tls=True
#   Gmail:     smtp://user:app-password@smtp.gmail.com:587/?tls=True
EMAIL_URL=                                    # [REQUIRED] SMTP connection URL
DEFAULT_FROM_EMAIL=noreply@yourdomain.com     # [REQUIRED] Sender email address

# -----------------------------------------------------------------------------
# Webhooks
# -----------------------------------------------------------------------------
WEBHOOK_SECRET_KEY=                           # [REQUIRED] Random secret for webhook signatures (min 32 chars)

# RSA key for webhook JWS verification (generate with: openssl genrsa -out private.pem 2048)
# Paste the full PEM content including BEGIN/END markers
RSA_PRIVATE_KEY=

# -----------------------------------------------------------------------------
# Media Storage (choose one)
# -----------------------------------------------------------------------------
# Option A: AWS S3
AWS_MEDIA_BUCKET_NAME=                        # S3 bucket name
AWS_ACCESS_KEY_ID=                            # IAM access key
AWS_SECRET_ACCESS_KEY=                        # IAM secret key
AWS_S3_REGION_NAME=us-east-1                  # AWS region
AWS_STATIC_CUSTOM_DOMAIN=                     # CloudFront domain (e.g., cdn.yourdomain.com)
AWS_S3_URL_PROTOCOL=https:

# Option B: Google Cloud Storage
# GS_MEDIA_BUCKET_NAME=                       # GCS bucket name
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/credentials.json

# Option C: Azure Blob Storage
# AZURE_ACCOUNT_NAME=
# AZURE_ACCOUNT_KEY=
# AZURE_CONTAINER=

# If no cloud storage is set, files are stored locally in /app/media/
MEDIA_URL=/media/

# -----------------------------------------------------------------------------
# Observability
# -----------------------------------------------------------------------------
SENTRY_DSN=                                   # Sentry DSN for error tracking (backend)
NEXT_PUBLIC_SENTRY_DSN=                       # Sentry DSN for frontend apps
OTEL_ENABLED=false                            # OpenTelemetry tracing
LOG_LEVEL=info                                # Logging level: debug, info, warning, error

# -----------------------------------------------------------------------------
# Stripe Payment App
# -----------------------------------------------------------------------------
STRIPE_PUBLISHABLE_KEY=                       # [REQUIRED] Stripe publishable key (pk_live_...)
STRIPE_SECRET_KEY=                            # [REQUIRED] Stripe secret key (sk_live_...)
STRIPE_WEBHOOK_SECRET=                        # [REQUIRED] Stripe webhook secret (whsec_...)
STRIPE_APP_SECRET_KEY=                        # [REQUIRED] App-level secret (random, min 32 chars)
STRIPE_APP_URL=https://stripe-app.yourdomain.com  # External URL for Stripe app

# -----------------------------------------------------------------------------
# Storefront (Next.js)
# -----------------------------------------------------------------------------
NEXT_PUBLIC_SALEOR_API_URL=https://api.yourdomain.com/graphql/   # [REQUIRED] Public GraphQL URL
NEXT_PUBLIC_STOREFRONT_URL=https://shop.yourdomain.com            # [REQUIRED] Storefront URL
NEXT_PUBLIC_DEFAULT_CHANNEL=usd                                   # Default channel slug
SALEOR_API_URL=http://aura-api:8000/graphql/                    # Internal API URL (Docker network)
SALEOR_APP_TOKEN=                                                 # App token for Storefront Control config fetch

# Next.js output mode
NEXT_OUTPUT=standalone                        # Use 'standalone' for Docker deployment

# -----------------------------------------------------------------------------
# Dashboard
# -----------------------------------------------------------------------------
VITE_API_URL=https://api.yourdomain.com/graphql/
VITE_APPS_MARKETPLACE_API_URL=https://apps.saleor.io/api/v2/saleor-apps

# -----------------------------------------------------------------------------
# Backup Configuration (used by backup-db.sh)
# -----------------------------------------------------------------------------
BACKUP_S3_BUCKET=                             # S3 bucket for database backups
BACKUP_S3_PREFIX=database-backups             # S3 key prefix
BACKUP_RETENTION_DAYS=30                      # Keep backups for N days
