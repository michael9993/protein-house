# ============================================================================
# Aura E-Commerce Platform — Service Registry (Template)
# ============================================================================
# Single source of truth for all services, ports, containers, and tunnels.
# Used by platform.ps1 and all infra scripts.
#
# SETUP: The `platform.ps1 new-store` wizard populates this file automatically.
# You can also copy this file to `platform.yml` and edit manually.
# ============================================================================

platform:
  name: "My Store E-Commerce"
  domain: "mystore.example.com"
  tunnel_name: "mystore-platform"
  compose_files:
    dev: "docker-compose.dev.yml"
    prod: "docker-compose.prod.yml"

backup:
  directory: "~/saleor-backups"
  retain: 30
  compress: true

store:
  name: "My Store"
  slug: "mystore"
  tagline: "Your tagline here"
  type: "physical"
  email: "support@mystore.example.com"
  phone: ""
  address:
    street: ""
    city: ""
    country: ""
  colors:
    primary: "#1B2838"
    secondary: "#1E4D3A"
    accent: "#C9A962"
  analytics:
    gtm_id: ""
    ga4_id: ""

services:
  api:
    port: 8000
    container: "aura-api-dev"
    compose_service: "aura-api"
    subdomain: "api"
    health_path: "/graphql/"
    health_check: true
    tunnel_env_var: "SALEOR_API_TUNNEL_URL"
    description: "Saleor GraphQL API"

  dashboard:
    port: 9000
    container: "aura-dashboard-dev"
    compose_service: "aura-dashboard"
    subdomain: "dash"
    health_path: "/"
    tunnel_env_var: "DASHBOARD_TUNNEL_URL"
    description: "Admin Dashboard"

  storefront:
    port: 3000
    container: "aura-storefront-dev"
    compose_service: "aura-storefront"
    subdomain: "shop"
    health_path: "/"
    tunnel_env_var: "STOREFRONT_TUNNEL_URL"
    description: "Customer Storefront"

  worker:
    container: "aura-worker-dev"
    compose_service: "aura-worker"
    description: "Celery background worker"

  scheduler:
    container: "aura-scheduler-dev"
    compose_service: "aura-scheduler"
    description: "Celery beat scheduler"

  postgres:
    port: 5432
    container: "aura-postgres-dev"
    compose_service: "postgres"
    health_check: true
    description: "PostgreSQL database"

  redis:
    port: 6379
    container: "aura-redis-dev"
    compose_service: "redis"
    health_check: true
    description: "Redis cache/broker"

  stripe:
    port: 3002
    container: "aura-stripe-app-dev"
    compose_service: "aura-stripe-app"
    subdomain: "stripe"
    tunnel_env_var: "STRIPE_APP_TUNNEL_URL"
    app_id: "stripe"
    app_manifest_path: "/api/manifest"
    permissions:
      - "HANDLE_PAYMENTS"
    description: "Stripe Payment App"

  smtp:
    port: 3001
    container: "aura-smtp-app-dev"
    compose_service: "aura-smtp-app"
    subdomain: "smtp"
    tunnel_env_var: "SMTP_APP_TUNNEL_URL"
    app_id: "saleor.app.smtp"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_ORDERS"
      - "MANAGE_USERS"
      - "MANAGE_GIFT_CARD"
    description: "SMTP Email App"

  invoices:
    port: 3003
    container: "aura-invoice-app-dev"
    compose_service: "aura-invoice-app"
    subdomain: "invoices"
    tunnel_env_var: "INVOICE_APP_TUNNEL_URL"
    app_id: "saleor.app.invoices"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_ORDERS"
    description: "PDF Invoice App"

  control:
    port: 3004
    container: "aura-storefront-control-app-dev"
    compose_service: "aura-storefront-control-app"
    subdomain: "control"
    tunnel_env_var: "STOREFRONT_CONTROL_APP_TUNNEL_URL"
    app_id: "saleor.app.storefront-control"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_APPS"
      - "MANAGE_DISCOUNTS"
    description: "Storefront Control CMS App"

  newsletter:
    port: 3005
    container: "aura-newsletter-app-dev"
    compose_service: "aura-newsletter-app"
    subdomain: "newsletter"
    tunnel_env_var: "NEWSLETTER_APP_TUNNEL_URL"
    app_id: "saleor.app.newsletter"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_APPS"
      - "MANAGE_USERS"
    description: "Newsletter App"

  analytics:
    port: 3006
    container: "aura-sales-analytics-app-dev"
    compose_service: "aura-sales-analytics-app"
    subdomain: "analytics"
    tunnel_env_var: "SALES_ANALYTICS_APP_TUNNEL_URL"
    app_id: "saleor.app.sales-analytics"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_ORDERS"
      - "MANAGE_PRODUCTS"
      - "MANAGE_CHANNELS"
    description: "Sales Analytics App"

  bulk:
    port: 3007
    container: "aura-bulk-manager-app-dev"
    compose_service: "aura-bulk-manager-app"
    subdomain: "bulk"
    tunnel_env_var: "BULK_MANAGER_APP_TUNNEL_URL"
    app_id: "saleor.app.bulk-manager"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_PRODUCTS"
      - "MANAGE_ORDERS"
      - "MANAGE_USERS"
      - "MANAGE_APPS"
      - "MANAGE_DISCOUNTS"
      - "MANAGE_GIFT_CARD"
      - "MANAGE_PRODUCT_TYPES_AND_ATTRIBUTES"
      - "MANAGE_PAGES"
      - "MANAGE_PAGE_TYPES_AND_ATTRIBUTES"
      - "MANAGE_TRANSLATIONS"
    description: "Bulk Import/Export Manager"

  studio:
    port: 3008
    container: "aura-image-studio-app-dev"
    compose_service: "aura-image-studio-app"
    subdomain: "studio"
    tunnel_env_var: "IMAGE_STUDIO_APP_TUNNEL_URL"
    app_id: "saleor.app.image-studio"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_PRODUCTS"
      - "MANAGE_APPS"
    description: "AI Image Studio App"

  dropship:
    port: 3009
    container: "aura-dropship-app-dev"
    compose_service: "aura-dropship-app"
    subdomain: "dropship"
    tunnel_env_var: "DROPSHIP_APP_TUNNEL_URL"
    app_id: "saleor.app.dropship-orchestrator"
    app_manifest_path: "/api/manifest"
    permissions:
      - "MANAGE_PRODUCTS"
      - "MANAGE_PRODUCT_TYPES_AND_ATTRIBUTES"
      - "MANAGE_ORDERS"
      - "MANAGE_APPS"
      - "MANAGE_SHIPPING"
      - "MANAGE_CHECKOUTS"
      - "MANAGE_CHANNELS"
    description: "Dropship Orchestrator App"

  tax:
    port: 3010
    container: "aura-tax-manager-app-dev"
    compose_service: "aura-tax-manager-app"
    subdomain: "tax"
    tunnel_env_var: "TAX_MANAGER_APP_TUNNEL_URL"
    app_id: "saleor.app.tax-manager"
    app_manifest_path: "/api/manifest"
    permissions:
      - "HANDLE_TAXES"
      - "MANAGE_APPS"
    description: "Tax Manager App"

  paypal:
    port: 3011
    container: "aura-paypal-app-dev"
    compose_service: "aura-paypal-app"
    subdomain: "ext1"
    tunnel_env_var: "PAYPAL_APP_TUNNEL_URL"
    app_id: "saleor.app.payment.paypal"
    app_manifest_path: "/api/manifest"
    permissions:
      - "HANDLE_PAYMENTS"
      - "MANAGE_ORDERS"
    description: "PayPal Payment App"
