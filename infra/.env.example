# ============================================================================
#  AURA PLATFORM — ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
#
#  This is the canonical environment template for the Aura E-Commerce Platform.
#
#  HOW IT GETS POPULATED:
#    platform.ps1 init       → copies this to .env, auto-generates secrets
#    platform.ps1 new-store  → fills store identity (name, colors, domain)
#
#  VALUE MARKERS:
#    __AUTO__    = Auto-generated by `platform.ps1 init` (secrets, keys)
#    __WIZARD__  = Set interactively by `platform.ps1 new-store`
#    __MANUAL__  = You must set this yourself (API keys, credentials)
#    (no marker) = Sensible development default, change as needed
#
#  NAMING CONVENTIONS:
#    NEXT_PUBLIC_*  = Baked into storefront at BUILD time (browser-visible)
#    VITE_*         = Baked into dashboard at BUILD time (browser-visible)
#    *_TUNNEL_URL   = Public URL when using Cloudflare/ngrok tunnels
#    *_APP_URL      = Internal/local URL for app webhook registration
#
# ============================================================================


# ============================================================================
# DOCKER NAMESPACING
# ============================================================================
# Prefix for Docker container names. Prevents conflicts when running multiple
# stores on the same machine. The new-store wizard sets this from your store slug.
# Examples: aura-api-dev, coolshoes-api-dev, pawzen-api-dev
COMPOSE_PREFIX=aura

# Docker Compose project name — namespaces volumes and networks.
# Should match COMPOSE_PREFIX to keep everything aligned.
COMPOSE_PROJECT_NAME=aura


# ============================================================================
# SERVICE PORTS
# ============================================================================
# Host-side ports mapped to containers. Change if you have port conflicts.
# Internal container ports are fixed (8000, 9000, 3000, etc.) — these control
# the HOST side only.

# Infrastructure
POSTGRES_PORT=5432               # PostgreSQL database
REDIS_PORT=6379                  # Redis cache / Celery broker

# Core services
SALEOR_API_PORT=8000             # Saleor GraphQL API (Django)
DASHBOARD_PORT=9000              # Admin dashboard (Vite/React)
STOREFRONT_PORT=3000             # Customer storefront (Next.js)

# Saleor Apps
SMTP_APP_PORT=3001               # SMTP email notifications
STRIPE_APP_PORT=3002             # Stripe payment processing
INVOICE_APP_PORT=3003            # PDF invoice generation
STOREFRONT_CONTROL_APP_PORT=3004 # CMS configuration / Storefront Control
NEWSLETTER_APP_PORT=3005         # Newsletter management
SALES_ANALYTICS_APP_PORT=3006    # Sales analytics & KPIs
BULK_MANAGER_APP_PORT=3007       # Bulk import/export (CSV/Excel)
IMAGE_STUDIO_APP_PORT=3008       # AI-powered image editor
DROPSHIP_APP_PORT=3009           # Dropship orchestrator (AliExpress + CJ)
TAX_MANAGER_APP_PORT=3010        # Self-hosted tax calculation engine
PAYPAL_APP_PORT=3011             # PayPal Commerce payments

# AI microservices (used by Image Studio)
# REMBG_PORT=7000                # AI background removal (rembg)
# ESRGAN_PORT=7001               # AI image upscaling (Real-ESRGAN)


# ============================================================================
# DATABASE
# ============================================================================
# PostgreSQL credentials. For production, use strong unique values.
POSTGRES_USER=aura
POSTGRES_PASSWORD=aura
POSTGRES_DB=aura

# Connection string — assembled from the above. Uses Docker service name.
# Override only if using an external database.
# DATABASE_URL=postgres://aura:aura@aura-postgres:5432/aura

# Connection pooling (seconds). 0 = close after each request. 60+ recommended for production.
DB_CONN_MAX_AGE=60


# ============================================================================
# REDIS
# ============================================================================
# Redis connection URLs using Docker service name.
# DB 0 = general cache, DB 1 = Celery broker, DB 2 = Celery results
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# Redis password — leave empty for dev, set for production
# When set, update REDIS_URL to: redis://:yourpassword@redis:6379/0
# REDIS_PASSWORD=


# ============================================================================
# SECRETS
# ============================================================================
# All secrets are auto-generated by `platform.ps1 init`.
# To generate manually: openssl rand -hex 32

# Django secret key — used for session signing, CSRF tokens, password hashing
SECRET_KEY=__AUTO__

# Shared encryption key for all Saleor apps (auth tokens, credentials)
APP_SECRET_KEY=__AUTO__

# RSA private key for webhook JWS signing (PEM format, \n for newlines)
# API, Worker, and Scheduler MUST share the same key — otherwise apps get
# 401 SIGNATURE_VERIFICATION_FAILED on webhooks.
# Generate manually: openssl genrsa 2048
RSA_PRIVATE_KEY=__AUTO__

# RSA key passphrase (optional — leave empty if key is not passphrase-protected)
RSA_PRIVATE_PASSWORD=

# Webhook secret key (optional — additional webhook payload signing)
WEBHOOK_SECRET_KEY=


# ============================================================================
# DJANGO / SALEOR API SETTINGS
# ============================================================================
# Debug mode — shows detailed error pages. MUST be False in production.
DEBUG=True

# Allowed hosts (comma-separated). Add your domain for tunnel/production.
# The Docker service name (aura-api) is required for container health checks.
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,aura-api

# Allowed client hosts for CSRF validation (comma-separated, host:port format)
ALLOWED_CLIENT_HOSTS=localhost:3000,localhost:9000,127.0.0.1:9000

# CORS allowed origins. Use * for development, specific URLs for production.
ALLOWED_GRAPHQL_ORIGINS=*

# Public URL — used for JWT token issuer and webhook signature verification.
# When using tunnels, SALEOR_API_TUNNEL_URL overrides this automatically.
PUBLIC_URL=http://localhost:8000

# GraphQL Playground — interactive API explorer at /graphql/. Disable in production.
GRAPHQL_PLAYGROUND_ENABLED=True

# Disable SSL redirect for Docker internal HTTP traffic.
# Set to False when TLS is terminated externally (Cloudflare tunnel, nginx, etc.)
# SECURE_SSL_REDIRECT=False


# ============================================================================
# INTERNAL URLS (Docker service hostnames — container-to-container)
# ============================================================================
# These use Docker service names for direct container communication.
# NEVER expose these to browsers — they can't resolve Docker hostnames.

# Server-side API URL (used by storefront SSR, apps, workers)
SALEOR_API_URL=http://aura-api:8000/graphql/


# ============================================================================
# PUBLIC URLS (browser-accessible)
# ============================================================================
# These must be reachable from the user's browser.
# For local dev: localhost. For production: your domain.

# Storefront URL — used by Saleor for abandoned checkout recovery emails
STOREFRONT_URL=http://localhost:3000

# Dashboard URL — used for CORS and link generation
# DASHBOARD_URL=http://localhost:9000


# ============================================================================
# STORE IDENTITY
# ============================================================================
# Set by `platform.ps1 new-store` wizard. Propagated to dashboard, storefront,
# email templates, and Storefront Control defaults.

# Store name — displayed in dashboard header, email subjects, page titles
STORE_NAME=__WIZARD__

# Store email — used as default sender in transactional emails, contact forms
STORE_EMAIL=__WIZARD__

# Platform domain — your self-hosted domain (e.g., mystore.com)
PLATFORM_DOMAIN=


# ============================================================================
# ADMIN CREDENTIALS
# ============================================================================
# Used by `platform.ps1 db-init` to create the initial superuser account.
# Change these before running setup in production!
AURA_ADMIN_EMAIL=admin@localhost
AURA_ADMIN_PASSWORD=admin

# Admin API URL for CLI scripts (host-side URL, not Docker service name)
AURA_API_URL=http://localhost:8000/graphql/


# ============================================================================
# EMAIL / SMTP
# ============================================================================
# Django email backend URL.
# Dev: consolemail:// (prints to container logs)
# Gmail: smtp://user:app-password@smtp.gmail.com:587/?ssl=tls
# Custom: smtp://user:pass@host:port/?ssl=tls
EMAIL_URL=consolemail://

# Default "From" address for transactional emails (order confirmations, invoices)
DEFAULT_FROM_EMAIL=noreply@localhost

# Contact form notification recipient (support inbox)
CONTACT_EMAIL=support@localhost

# SMTP credentials (used by the SMTP app for sending via external provider)
# For Gmail: generate an App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=TLS
SMTP_USER=__MANUAL__
SMTP_PASSWORD=__MANUAL__
SMTP_FROM_EMAIL=__WIZARD__
SMTP_FROM_NAME="__WIZARD__"


# ============================================================================
# STOREFRONT (Next.js — NEXT_PUBLIC_* vars are baked at BUILD time)
# ============================================================================
# BROWSER-SIDE API URL — must be reachable from the user's browser.
# Local dev: http://localhost:8000/graphql/
# Production: https://api.yourdomain.com/graphql/
# NEVER use http://aura-api:8000 here — browsers can't resolve Docker hostnames.
NEXT_PUBLIC_SALEOR_API_URL=http://localhost:8000/graphql/

# Public storefront URL (used for og:url, canonical links, sitemap)
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000

# Default channel slug (used when no channel is specified in URL)
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel

# Comma-separated channel slugs for config fetching (e.g., "ils,usd")
STOREFRONT_CHANNELS=

# Saleor App Token — for server-side operations (generated during app install)
SALEOR_APP_TOKEN=

# External image domains for Next.js <Image> (comma-separated, for remotePatterns)
NEXT_PUBLIC_IMAGE_DOMAINS=

# Coming soon mode — set to "true" to show a coming soon page instead of the store
# NEXT_PUBLIC_COMING_SOON=false

# Google Maps API key — for store locator / address autocomplete (optional)
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# SMTP App URL for client-side contact forms (internal Docker URL)
# NEXT_PUBLIC_SMTP_APP_URL=http://localhost:3001

# Storefront build mode: 'dev' (hot-reload) or 'production' (optimized build)
STOREFRONT_MODE=dev


# ============================================================================
# DASHBOARD (Vite — VITE_* vars are baked at BUILD time)
# ============================================================================
# API URL for Dashboard GraphQL requests
API_URL=http://localhost:8000/graphql/
VITE_API_URL=http://localhost:8000/graphql/

# Saleor App Marketplace API (leave empty to disable marketplace)
APPS_MARKETPLACE_API_URL=

# Extensions API URL (leave empty to disable)
EXTENSIONS_API_URL=

# Dashboard mount path and static URL
APP_MOUNT_URI=/dashboard/
STATIC_URL=/dashboard/

# Store branding — baked into dashboard build
VITE_STORE_NAME=__WIZARD__
VITE_PLATFORM_NAME=__WIZARD__

# Disable React StrictMode (helps RichTextEditor/Combobox stability in Docker)
# VITE_DISABLE_STRICT_MODE=true

# Code inspector for development (true/false)
ENABLE_CODE_INSPECTOR=false

# AI Assistant — Claude-powered assistant in dashboard sidebar
# Set to "true" to enable, requires VITE_AI_API_KEY
# VITE_AI_ASSISTANT_ENABLED=false
# VITE_AI_API_KEY=__MANUAL__
# VITE_AI_MODEL=claude-haiku-4-5-20251001


# ============================================================================
# AI SERVICES (Optional — used by Image Studio app)
# ============================================================================
# Google Gemini API key — for AI background generation in Image Studio
# Get from: https://aistudio.google.com/apikey
# GEMINI_API_KEY=__MANUAL__

# OpenAI API key — for AI features (future use)
# Get from: https://platform.openai.com/api-keys
# OPENAI_API_KEY=__MANUAL__

# Stability AI API key — for image generation/editing in Image Studio
# Get from: https://platform.stability.ai/account/keys
# STABILITY_API_KEY=__MANUAL__


# ============================================================================
# PAYMENT PROVIDERS
# ============================================================================

# --- Stripe ---
# Get test keys from: https://dashboard.stripe.com/test/apikeys
# Stripe credentials are configured in Dashboard > Apps > Stripe, but these
# env vars are used for server-side operations and webhook verification.
STRIPE_PUBLISHABLE_KEY=__MANUAL__
STRIPE_SECRET_KEY=__MANUAL__
STRIPE_WEBHOOK_SECRET=__MANUAL__
STRIPE_RESTRICTED_KEY=
STRIPE_APP_TOKEN=
STRIPE_APP_URL=http://localhost:3002
STRIPE_APP_API_BASE_URL=http://localhost:3002

# --- PayPal ---
# Get credentials from: https://developer.paypal.com/dashboard/applications
# Use Sandbox credentials for development, Live for production.
# PAYPAL_CLIENT_ID=__MANUAL__
# PAYPAL_SECRET_KEY=__MANUAL__
PAYPAL_APP_URL=http://localhost:3011
PAYPAL_APP_API_BASE_URL=http://localhost:3011


# ============================================================================
# TUNNEL URLS (Optional — Cloudflare / ngrok tunnels for public access)
# ============================================================================
# Uncomment and set these when using named tunnels for external access.
# SALEOR_API_TUNNEL_URL is used as Saleor PUBLIC_URL so webhook JWT succeeds.
# Run `platform.ps1 generate-tunnel-config` to regenerate cloudflared-config.yml.
#
# SALEOR_API_TUNNEL_URL=https://api.yourdomain.com
# DASHBOARD_TUNNEL_URL=https://dash.yourdomain.com
# STOREFRONT_TUNNEL_URL=https://shop.yourdomain.com
# STRIPE_APP_TUNNEL_URL=https://stripe.yourdomain.com
# SMTP_APP_TUNNEL_URL=https://smtp.yourdomain.com
# INVOICE_APP_TUNNEL_URL=https://invoices.yourdomain.com
# STOREFRONT_CONTROL_APP_TUNNEL_URL=https://control.yourdomain.com
# NEWSLETTER_APP_TUNNEL_URL=https://newsletter.yourdomain.com
# SALES_ANALYTICS_APP_TUNNEL_URL=https://analytics.yourdomain.com
# BULK_MANAGER_APP_TUNNEL_URL=https://bulk.yourdomain.com
# IMAGE_STUDIO_APP_TUNNEL_URL=https://studio.yourdomain.com
# DROPSHIP_APP_TUNNEL_URL=https://dropship.yourdomain.com
# TAX_MANAGER_APP_TUNNEL_URL=https://tax.yourdomain.com
# PAYPAL_APP_TUNNEL_URL=https://paypal.yourdomain.com

# Dashboard tunnel URL — required for Vite allowedHosts when accessing via tunnel.
# Without this, you'll get "Blocked request" errors in the browser.
DASHBOARD_TUNNEL_URL=


# ============================================================================
# MEDIA STORAGE
# ============================================================================
# Default: local filesystem (Docker volume). For production, use cloud storage.

# Media URL prefix (for serving uploaded files)
# Local dev: /media/ (served by Django)
# Production: https://your-cdn.com/media/ or https://bucket.s3.amazonaws.com/media/
# MEDIA_URL=/media/

# --- AWS S3 (uncomment for production) ---
# AWS_STORAGE_BUCKET_NAME=your-bucket
# AWS_MEDIA_BUCKET_NAME=your-media-bucket
# AWS_ACCESS_KEY_ID=__MANUAL__
# AWS_SECRET_ACCESS_KEY=__MANUAL__
# AWS_S3_REGION_NAME=us-east-1
# AWS_S3_CUSTOM_DOMAIN=cdn.yourdomain.com
# AWS_S3_ENDPOINT_URL=
# AWS_DEFAULT_ACL=public-read
# AWS_QUERYSTRING_AUTH=False

# --- Google Cloud Storage (uncomment for production) ---
# GS_BUCKET_NAME=your-bucket
# GS_MEDIA_BUCKET_NAME=your-media-bucket
# GS_PROJECT_ID=your-project-id
# GS_CUSTOM_ENDPOINT=


# ============================================================================
# APP CONFIGURATION
# ============================================================================
# App Persistence Layer: how Saleor apps store their auth tokens.
# 'file' = local filesystem (dev), 'rest' or 'env' = external store (production)
APL=file

# App URLs — used for webhook registration. In tunneled setups, the TUNNEL_URL
# takes precedence automatically via docker-compose defaults.
INVOICE_APP_URL=http://localhost:3003
INVOICE_APP_API_BASE_URL=http://localhost:3003
STOREFRONT_CONTROL_APP_URL=http://localhost:3004
NEWSLETTER_APP_URL=http://localhost:3005
SALES_ANALYTICS_APP_URL=http://localhost:3006
BULK_MANAGER_APP_URL=http://localhost:3007
IMAGE_STUDIO_APP_URL=http://localhost:3008

# Auto-update sample config JSON when saving in Storefront Control admin
AUTO_UPDATE_SAMPLE_CONFIG=true

# Newsletter image storage backend: 'local' (dev) or 's3' (production)
NEWSLETTER_IMAGE_STORAGE=local

# Dropship orchestrator — encryption key for supplier credentials
# Uses APP_SECRET_KEY by default; override for per-app isolation
# DROPSHIP_SECRET_KEY=


# ============================================================================
# GRAPHQL CLIENT CONFIG (Storefront urql client)
# ============================================================================
# Controls retry behavior for storefront GraphQL requests to Saleor API.
GRAPHQL_TIMEOUT_MS=30000         # Request timeout in milliseconds
GRAPHQL_MAX_RETRIES=4            # Max retry attempts on failure
GRAPHQL_RETRY_DELAY_MS=1000      # Base delay between retries (exponential backoff: delay * 2^attempt)


# ============================================================================
# RUNTIME MODE
# ============================================================================
# Node environment — affects all Node.js containers
NODE_ENV=development

# Apps build mode: 'dev' (hot-reload) or 'production' (build then start)
# Applies to: SMTP, Invoice, Stripe, Storefront Control, Newsletter, etc.
APPS_MODE=dev

# OpenTelemetry instrumentation (true/false) — enable for production observability
OTEL_ENABLED=false


# ============================================================================
# SECURITY
# ============================================================================
# Password reset link expiry (seconds). Default 86400 = 24 hours.
PASSWORD_RESET_TIMEOUT=86400

# Lockout time after too many failed password reset attempts (minutes)
RESET_PASSWORD_LOCK_TIME=15


# ============================================================================
# MONITORING & ERROR TRACKING
# ============================================================================
# Sentry DSN — get from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Sentry auth token for source map uploads (improves stack traces)
SENTRY_AUTH_TOKEN=


# ============================================================================
# OAUTH (Optional — Social login)
# ============================================================================
# Google OAuth2 for social login
# GOOGLE_CLIENT_ID=__MANUAL__
# GOOGLE_CLIENT_SECRET=__MANUAL__


# ============================================================================
# TIMEZONE
# ============================================================================
TIME_ZONE=UTC


# ============================================================================
# PLATFORM OPERATIONS
# ============================================================================
# Directory for database backups (host path)
SALEOR_BACKUP_DIR=~/saleor-backups


# ============================================================================
# PRODUCTION-ONLY SETTINGS (uncomment for production deployments)
# ============================================================================
# These are used by docker-compose.prod.yml and should remain commented
# for local development.

# --- Scaling ---
# GUNICORN_WORKERS=4             # Number of Gunicorn workers for Saleor API
# CELERY_CONCURRENCY=4           # Number of concurrent Celery worker processes

# --- Per-app secret keys (production isolation) ---
# In dev, all apps share APP_SECRET_KEY. In production, use unique keys per app.
# SMTP_APP_SECRET_KEY=__AUTO__
# STRIPE_APP_SECRET_KEY=__AUTO__
# INVOICES_APP_SECRET_KEY=__AUTO__
# STOREFRONT_CONTROL_APP_SECRET_KEY=__AUTO__
# NEWSLETTER_APP_SECRET_KEY=__AUTO__
# ANALYTICS_APP_SECRET_KEY=__AUTO__
# BULK_MANAGER_APP_SECRET_KEY=__AUTO__

# --- Production app URLs (tunnel URLs used directly) ---
# SMTP_APP_URL=https://smtp.yourdomain.com
# INVOICES_APP_URL=https://invoices.yourdomain.com
# ANALYTICS_APP_URL=https://analytics.yourdomain.com

# --- App tunnel keyword routing ---
# APPS_TUNNEL_URL_KEYWORDS=


# ============================================================================
# BUILD-TIME VARIABLE WARNING
# ============================================================================
#
# Variables prefixed with NEXT_PUBLIC_ or VITE_ are embedded into the
# JavaScript bundle at BUILD time, NOT at runtime.
#
# This means:
#   1. Changing these in .env requires REBUILDING the container, not just
#      restarting it: docker compose up --build <service>
#   2. They are visible to end users in the browser (never put secrets here)
#   3. For storefront: NEXT_PUBLIC_SALEOR_API_URL, NEXT_PUBLIC_STOREFRONT_URL,
#      NEXT_PUBLIC_DEFAULT_CHANNEL, etc.
#   4. For dashboard: VITE_API_URL, VITE_STORE_NAME, VITE_PLATFORM_NAME,
#      VITE_AI_ASSISTANT_ENABLED, etc.
#
# In this Docker setup, containers rebuild on startup (dev mode runs the
# build step in the entrypoint), so a restart IS effectively a rebuild.
# But in production (pre-built images), you MUST rebuild the image.
#
# ============================================================================
