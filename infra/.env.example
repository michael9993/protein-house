# ============================================================================
# SALEOR PLATFORM - ENVIRONMENT CONFIGURATION TEMPLATE
# ============================================================================
# This is the canonical environment template. The `platform.ps1 init` command
# copies this file to `.env` and auto-generates secrets (SECRET_KEY,
# APP_SECRET_KEY, RSA_PRIVATE_KEY). The `platform.ps1 new-store` command
# populates brand-specific values (store name, domain, etc.).
#
# Values marked __AUTO_GENERATED__ are filled automatically by `platform.ps1 init`.
# Values marked __SET_BY_WIZARD__ are filled by `platform.ps1 new-store`.
# All other values have sensible dev defaults.
# ============================================================================

# ============================================================================
# ============================================================================
# DOCKER NAMESPACING
# ============================================================================
# Prefix for Docker container names. Prevents conflicts when running multiple
# stores on the same machine. The new-store wizard sets this from your store slug.
# Examples: aura-api-dev, coolshoes-api-dev, pawzen-api-dev
COMPOSE_PREFIX=aura
# Docker Compose project name — namespaces volumes and networks.
# Should match COMPOSE_PREFIX to keep everything aligned.
COMPOSE_PROJECT_NAME=aura

# SERVICE PORTS
# ============================================================================
POSTGRES_PORT=5432
REDIS_PORT=6379
SALEOR_API_PORT=8000
DASHBOARD_PORT=9000
STOREFRONT_PORT=3000
STRIPE_APP_PORT=3002
SMTP_APP_PORT=3001
INVOICE_APP_PORT=3003
STOREFRONT_CONTROL_APP_PORT=3004
NEWSLETTER_APP_PORT=3005
SALES_ANALYTICS_APP_PORT=3006
BULK_MANAGER_APP_PORT=3007
IMAGE_STUDIO_APP_PORT=3008
DROPSHIP_APP_PORT=3009
TAX_MANAGER_APP_PORT=3010
PAYPAL_APP_PORT=3011

# ============================================================================
# DATABASE CONFIGURATION
# ============================================================================
POSTGRES_USER=saleor
POSTGRES_PASSWORD=saleor
POSTGRES_DB=saleor
# Database connection pooling (in seconds)
# Set to 0 to disable (connections closed after each request)
# Set to 60+ to enable connection reuse (recommended for production)
DB_CONN_MAX_AGE=60

# ============================================================================
# ADMIN CREDENTIALS
# ============================================================================
# Used by `platform.ps1 db-init` to create the initial superuser.
# Change these before running setup in production.
AURA_ADMIN_EMAIL=admin@localhost
AURA_ADMIN_PASSWORD=admin
AURA_API_URL=http://localhost:8000/graphql/

# ============================================================================
# SALEOR API CONFIGURATION
# ============================================================================
# Django Secret Key — auto-generated by `platform.ps1 init`
# Generate manually with: openssl rand -hex 32
SECRET_KEY=__AUTO_GENERATED__

# Debug mode (True/False) — disable in production to hide error details
DEBUG=True

# Allowed hosts (comma-separated) — add your domain for tunnel/production
ALLOWED_HOSTS=localhost,127.0.0.1,0.0.0.0,saleor-api

# Allowed client hosts (comma-separated) — add your domain for tunnel/production
ALLOWED_CLIENT_HOSTS=localhost:3000,localhost:9000,127.0.0.1:9000

# CORS allowed origins (* for development, specific URLs for production)
ALLOWED_GRAPHQL_ORIGINS=*

# Public URL - Used for JWT token issuer URL (required for webhook signature verification).
# When using tunnels, set SALEOR_API_TUNNEL_URL in the tunnel section below; Saleor will use
# it as PUBLIC_URL so SMTP/app webhooks succeed (otherwise 401 SIGNATURE_VERIFICATION_FAILED).
PUBLIC_URL=http://localhost:8000

# GraphQL Playground — set to False in production
GRAPHQL_PLAYGROUND_ENABLED=True

# Disable SSL redirect for Docker internal HTTP traffic
# Set to False when TLS is terminated externally (Cloudflare tunnel, nginx, etc.)
# SECURE_SSL_REDIRECT=False

# Email configuration (consolemail:// prints to console, smtp://user:pass@host:port for real SMTP)
EMAIL_URL=consolemail://
DEFAULT_FROM_EMAIL=noreply@localhost
CONTACT_EMAIL=support@localhost

# Timezone
TIME_ZONE=UTC

# Password reset and account confirmation link expiry (seconds). Default 86400 = 24 hours.
PASSWORD_RESET_TIMEOUT=86400
# Lockout time after too many failed password reset attempts (minutes)
RESET_PASSWORD_LOCK_TIME=15

# Webhook secret key (optional)
WEBHOOK_SECRET_KEY=

# RSA private key for webhook JWS signing — auto-generated by `platform.ps1 init`
# Saleor API, Worker, and Scheduler must use the SAME key; otherwise apps get 401 SIGNATURE_VERIFICATION_FAILED.
# Generate manually with: openssl genrsa 2048 (then paste PEM; use \n for newlines on a single line).
RSA_PRIVATE_KEY=__AUTO_GENERATED__

# Redis URLs (internal Docker service names)
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ============================================================================
# RUNTIME MODE
# ============================================================================
# Node environment (development/production) — affects all Node.js containers
NODE_ENV=development

# Storefront build mode: 'dev' (hot-reload) or 'production' (optimized build)
STOREFRONT_MODE=dev

# Apps build mode: 'dev' (hot-reload) or 'production' (build then start)
# Applies to: SMTP, Invoice, Stripe, Storefront Control, Newsletter, Sales Analytics, etc.
APPS_MODE=dev

# App Persistence Layer: 'file' (local dev) or 'rest'/'env' (production)
# Controls how app auth tokens are stored
APL=file

# OpenTelemetry instrumentation (true/false) — enable for production observability
OTEL_ENABLED=false

# ============================================================================
# TUNNEL URLs (Optional — only if using Cloudflare/ngrok tunnels)
# ============================================================================
# Uncomment and set these if you're using named tunnels for public access.
# SALEOR_API_TUNNEL_URL is used as Saleor PUBLIC_URL so webhook JWT verification succeeds.
#
# SALEOR_API_TUNNEL_URL=https://api.yourdomain.com
# DASHBOARD_TUNNEL_URL=https://dash.yourdomain.com
# STOREFRONT_TUNNEL_URL=https://shop.yourdomain.com
# STRIPE_APP_TUNNEL_URL=https://stripe.yourdomain.com
# SMTP_APP_TUNNEL_URL=https://smtp.yourdomain.com
# INVOICE_APP_TUNNEL_URL=https://invoices.yourdomain.com
# STOREFRONT_CONTROL_APP_TUNNEL_URL=https://control.yourdomain.com
# NEWSLETTER_APP_TUNNEL_URL=https://newsletter.yourdomain.com
# SALES_ANALYTICS_APP_TUNNEL_URL=https://analytics.yourdomain.com
# BULK_MANAGER_APP_TUNNEL_URL=https://bulk.yourdomain.com
# IMAGE_STUDIO_APP_TUNNEL_URL=https://studio.yourdomain.com
# DROPSHIP_APP_TUNNEL_URL=https://dropship.yourdomain.com
# TAX_MANAGER_APP_TUNNEL_URL=https://tax.yourdomain.com
# PAYPAL_APP_TUNNEL_URL=https://ext1.yourdomain.com

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================
# API URL for Dashboard GraphQL requests — baked at build time!
# Local dev: http://localhost:8000/graphql/
# Production with domain: https://api.yourdomain.com/graphql/
API_URL=http://localhost:8000/graphql/
VITE_API_URL=http://localhost:8000/graphql/
APPS_MARKETPLACE_API_URL=
EXTENSIONS_API_URL=
APP_MOUNT_URI=/dashboard/
STATIC_URL=/dashboard/
# Disable React StrictMode (helps RichTextEditor/Combobox in Docker)
# VITE_DISABLE_STRICT_MODE=true
# Store branding — set by `platform.ps1 new-store`
VITE_STORE_NAME=__SET_BY_WIZARD__
VITE_PLATFORM_NAME=__SET_BY_WIZARD__
# Code inspector for development (true/false)
ENABLE_CODE_INSPECTOR=false

# ============================================================================
# STOREFRONT CONFIGURATION
# ============================================================================
# BROWSER-SIDE API URL — must be reachable from the user's browser (NOT Docker service name!)
# Local dev: http://localhost:8000/graphql/
# Production with domain: https://api.yourdomain.com/graphql/
# NEVER use http://saleor-api:8000 here — browsers can't resolve Docker service names
NEXT_PUBLIC_SALEOR_API_URL=http://localhost:8000/graphql/
# SERVER-SIDE API URL — used inside Docker containers (SSR, server components)
# Should use Docker service name for direct container-to-container communication
SALEOR_API_URL=http://saleor-api:8000/graphql/
# Public storefront URL (used by frontends)
NEXT_PUBLIC_STOREFRONT_URL=http://localhost:3000
# Storefront URL for Saleor backend (abandoned checkout recovery emails)
# In production, set to your public storefront URL (e.g., https://shop.yourdomain.com)
STOREFRONT_URL=http://localhost:3000
# Default channel slug
NEXT_PUBLIC_DEFAULT_CHANNEL=default-channel
# Comma-separated channel slugs for config fetching (e.g., "ils,usd")
STOREFRONT_CHANNELS=
# Saleor App Token for server-side operations
SALEOR_APP_TOKEN=

# External image domains (comma-separated, for Next.js remotePatterns)
NEXT_PUBLIC_IMAGE_DOMAINS=

# GraphQL request timeout and retry configuration
GRAPHQL_TIMEOUT_MS=30000
GRAPHQL_MAX_RETRIES=4
GRAPHQL_RETRY_DELAY_MS=1000

# ============================================================================
# STRIPE PAYMENT APP CONFIGURATION
# ============================================================================
# Get test keys from: https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RESTRICTED_KEY=
STRIPE_APP_TOKEN=
STRIPE_APP_URL=http://localhost:3002
STRIPE_APP_API_BASE_URL=http://localhost:3002
# Shared encryption key for all apps — auto-generated by `platform.ps1 init`
# Generate manually with: openssl rand -hex 32
APP_SECRET_KEY=__AUTO_GENERATED__

# ============================================================================
# APP URLs (for webhook registration — use tunnel URLs for external access)
# ============================================================================
INVOICE_APP_URL=http://localhost:3003
INVOICE_APP_API_BASE_URL=http://localhost:3003
STOREFRONT_CONTROL_APP_URL=http://localhost:3004
NEWSLETTER_APP_URL=http://localhost:3005
SALES_ANALYTICS_APP_URL=http://localhost:3006
BULK_MANAGER_APP_URL=http://localhost:3007
IMAGE_STUDIO_APP_URL=http://localhost:3008
PAYPAL_APP_URL=http://localhost:3011
PAYPAL_APP_API_BASE_URL=http://localhost:3011
# Auto-update sample config on save (storefront control)
AUTO_UPDATE_SAMPLE_CONFIG=true

# ============================================================================
# SMTP EMAIL APP CONFIGURATION
# ============================================================================
# For Gmail: use App Password (https://myaccount.google.com/apppasswords)
SMTP_HOST=
SMTP_PORT=587
SMTP_ENCRYPTION=TLS
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME="__SET_BY_WIZARD__"

# ============================================================================
# OAUTH (Google Login — optional)
# ============================================================================
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ============================================================================
# AI SERVICES (Image Studio — optional)
# ============================================================================
# Gemini API key for AI background generation
# GEMINI_API_KEY=
# OpenAI API key (optional, for future features)
# OPENAPI_API_KEY=

# ============================================================================
# NEWSLETTER APP
# ============================================================================
# Image storage backend: 'local' (dev) or 's3' (production)
NEWSLETTER_IMAGE_STORAGE=local

# ============================================================================
# SENTRY ERROR MONITORING (Optional)
# ============================================================================
# Get your DSN from https://sentry.io → Project Settings → Client Keys
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
# Auth token for source map uploads (optional, improves stack traces)
SENTRY_AUTH_TOKEN=

# ============================================================================
# DROPSHIP ORCHESTRATOR APP CONFIGURATION
# ============================================================================
# Encryption key for supplier credentials (uses APP_SECRET_KEY by default)
# DROPSHIP_SECRET_KEY=

# ============================================================================
# PLATFORM CONFIGURATION
# ============================================================================
# Domain for self-hosted deployment — set by `platform.ps1 new-store`
PLATFORM_DOMAIN=
# Directory for database backups
SALEOR_BACKUP_DIR=~/saleor-backups

# ============================================================================
# DASHBOARD TUNNEL URL (for Vite allowedHosts in tunnel/production mode)
# ============================================================================
# Set to your dashboard tunnel URL (e.g., https://dash.yourdomain.com)
# Required when accessing dashboard via tunnel to avoid "Blocked request" errors
DASHBOARD_TUNNEL_URL=
