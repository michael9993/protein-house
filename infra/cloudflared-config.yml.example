# ============================================================================
# Cloudflare Tunnel Configuration (Template)
# ============================================================================
# This file is generated by `platform.ps1 new-store` when you provide a domain.
# You can also copy this template and edit manually.
#
# SETUP STEPS:
#   1. Install cloudflared: winget install Cloudflare.cloudflared
#   2. Login: cloudflared tunnel login
#   3. Create tunnel: cloudflared tunnel create mystore-platform
#   4. Copy the tunnel UUID from the output
#   5. Replace <TUNNEL_UUID> below with your tunnel UUID
#   6. Replace <YOUR_CREDENTIALS_PATH> with the path shown in step 3
#   7. Replace example.com with your actual domain
#   8. Create DNS CNAME records in Cloudflare Dashboard:
#      - example.com         -> <TUNNEL_UUID>.cfargotunnel.com
#      - api.example.com     -> <TUNNEL_UUID>.cfargotunnel.com
#      - dash.example.com    -> <TUNNEL_UUID>.cfargotunnel.com
#      - stripe.example.com  -> <TUNNEL_UUID>.cfargotunnel.com
#      - smtp.example.com    -> <TUNNEL_UUID>.cfargotunnel.com
#      - invoices.example.com -> <TUNNEL_UUID>.cfargotunnel.com
#      - control.example.com -> <TUNNEL_UUID>.cfargotunnel.com
#      - newsletter.example.com -> <TUNNEL_UUID>.cfargotunnel.com
#      - analytics.example.com -> <TUNNEL_UUID>.cfargotunnel.com
#      - bulk.example.com    -> <TUNNEL_UUID>.cfargotunnel.com
#      - studio.example.com  -> <TUNNEL_UUID>.cfargotunnel.com
#      - dropship.example.com -> <TUNNEL_UUID>.cfargotunnel.com
#      - tax.example.com     -> <TUNNEL_UUID>.cfargotunnel.com
#      - ext1.example.com    -> <TUNNEL_UUID>.cfargotunnel.com
#   9. Run tunnel: cloudflared tunnel --config infra/cloudflared-config.yml run
# ============================================================================

tunnel: <TUNNEL_UUID>
credentials-file: <YOUR_CREDENTIALS_PATH>

ingress:
  # Storefront (customer-facing)
  - hostname: example.com
    service: http://localhost:3000

  # Saleor GraphQL API
  - hostname: api.example.com
    service: http://localhost:8000

  # Admin Dashboard
  - hostname: dash.example.com
    service: http://localhost:9000

  # Stripe Payment App
  - hostname: stripe.example.com
    service: http://localhost:3002

  # SMTP Email App
  - hostname: smtp.example.com
    service: http://localhost:3001

  # Invoice App
  - hostname: invoices.example.com
    service: http://localhost:3003

  # Storefront Control CMS App
  - hostname: control.example.com
    service: http://localhost:3004

  # Newsletter App
  - hostname: newsletter.example.com
    service: http://localhost:3005

  # Sales Analytics App
  - hostname: analytics.example.com
    service: http://localhost:3006

  # Bulk Manager App
  - hostname: bulk.example.com
    service: http://localhost:3007

  # Image Studio App
  - hostname: studio.example.com
    service: http://localhost:3008

  # Dropship Orchestrator App
  - hostname: dropship.example.com
    service: http://localhost:3009

  # Tax Manager App
  - hostname: tax.example.com
    service: http://localhost:3010

  # PayPal Payment App
  - hostname: ext1.example.com
    service: http://localhost:3011

  # Catch-all (required by cloudflared)
  - service: http_status:404
