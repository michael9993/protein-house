# PayPal Payment App - Environment Variables
# Copy this file to .env and fill in the values

# Required: Secret key for encrypting stored credentials
SECRET_KEY=

# Optional: Override app manifest ID
MANIFEST_APP_ID=saleor.app.payment.paypal

# Optional: Override app display name
APP_NAME=PayPal

# Optional: Override base URLs (for tunnels)
APP_API_BASE_URL=
APP_IFRAME_BASE_URL=

# Optional: Restrict which Saleor instances can install this app
ALLOWED_DOMAIN_PATTERN=

# Optional: Log level (fatal, error, warn, info, debug, trace)
APP_LOG_LEVEL=info
