{
  "name": "saleor-app-newsletter",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "next build",
    "check-types": "tsc",
    "dev": "NODE_OPTIONS='--inspect' next dev --port 3000",
    "dev:debug": "APP_LOG_LEVEL=debug pnpm dev",
    "fetch-schema": "curl https://raw.githubusercontent.com/saleor/saleor/${npm_package_config_saleor_schemaVersion}/saleor/graphql/schema.graphql > graphql/schema.graphql",
    "generate": "graphql-codegen",
    "lint": "eslint .",
    "lint:fix": "eslint --fix .",
    "start": "next start"
  },
  "config": {
    "saleor": {
      "schemaVersion": "3.20"
    }
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@hookform/resolvers": "catalog:",
    "@saleor/app-sdk": "link:../../node_modules/@saleor/app-sdk",
    "@saleor/apps-shared": "workspace:*",
    "@saleor/apps-ui": "workspace:*",
    "@saleor/macaw-ui": "catalog:",
    "@saleor/react-hook-form-macaw": "workspace:*",
    "@tanstack/react-query": "catalog:",
    "@trpc/client": "catalog:",
    "@trpc/next": "catalog:",
    "@trpc/react-query": "catalog:",
    "@trpc/server": "catalog:",
    "bullmq": "^5.28.0",
    "date-fns-tz": "^3.0.0",
    "dotenv": "catalog:",
    "file-type": "^20.0.0",
    "formidable": "^3.5.1",
    "graphql": "catalog:",
    "graphql-tag": "catalog:",
    "handlebars": "^4.7.7",
    "ioredis": "^5.4.1",
    "mjml": "4.15.3",
    "@monaco-editor/react": "^4.4.6",
    "next": "catalog:",
    "nodemailer": "^6.9.8",
    "react": "catalog:",
    "react-dom": "catalog:",
    "react-hook-form": "catalog:",
    "sharp": "^0.33.5",
    "urql": "catalog:",
    "usehooks-ts": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@graphql-codegen/cli": "catalog:",
    "@graphql-codegen/introspection": "catalog:",
    "@graphql-codegen/typed-document-node": "catalog:",
    "@graphql-codegen/typescript": "catalog:",
    "@graphql-codegen/typescript-operations": "catalog:",
    "@graphql-codegen/typescript-urql": "catalog:",
    "@graphql-typed-document-node/core": "catalog:",
    "@saleor/eslint-config-apps": "workspace:*",
    "@saleor/typescript-config-apps": "workspace:*",
    "@types/mjml": "4.7.4",
    "@types/nodemailer": "^6.4.14",
    "@types/react": "18.2.5",
    "@types/react-dom": "18.2.5",
    "eslint": "catalog:",
    "graphql-config": "5.0.3",
    "null-loader": "4.0.1",
    "tsx": "catalog:",
    "typescript": "5.8.2"
  }
}
