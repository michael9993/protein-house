{
  "env": {
    "USE_BUILTIN_RIPGREP": "1",
    "CLAUDE_BASH_MAINTAIN_PROJECT_WORKING_DIR": "1",
    "CLAUDE_CODE_DISABLE_TERMINAL_TITLE": "0",
    "CLAUDE_CODE_MAX_OUTPUT_TOKENS": "32000",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1",
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
    "DISABLE_COST_WARNINGS": "1",
    "CLAUDE_CODE_NO_FLICKER": "1"
  },
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read(**)",
      "Edit(**)",
      "Write(**)",
      "Glob(**)",
      "Grep(**)",
      "WebFetch(*)",
      "WebSearch",
      "mcp__*",
      "Bash(find:*)",
      "mcp__plugin_context-mode_context-mode__ctx_batch_execute",
      "mcp__plugin_context-mode_context-mode__ctx_execute_file",
      "mcp__plugin_context-mode_context-mode__ctx_execute",
      "mcp__plugin_context-mode_context-mode__ctx_fetch_and_index",
      "mcp__plugin_context-mode_context-mode__ctx_search",
      "mcp__playwright-server__browser_navigate",
      "mcp__playwright-server__browser_evaluate",
      "mcp__playwright-server__browser_take_screenshot",
      "mcp__plugin_telegram_telegram__reply",
      "mcp__playwright-server__browser_snapshot",
      "Read(//c/Program Files/GitHub CLI//**)",
      "Read(//c/Program Files \\(x86\\)/**)",
      "Bash(where.exe gh:*)",
      "Read(//c/Users/micha/AppData/**)",
      "Bash(cmd.exe:*)"
    ],
    "deny": [
      "Bash(rm -rf /)",
      "Bash(rm -rf /*)",
      "Bash(sudo rm -rf:*)",
      "Bash(git push --force origin main:*)",
      "Bash(git push --force origin master:*)",
      "Bash(git reset --hard:*)",
      "Bash(sudo:*)"
    ]
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "memory",
    "context7",
    "playwright-server",
    "fetch",
    "Figma Dev Mode MCP",
    "sentry",
    "postgres-documentation",
    "markitdown"
  ]
}
