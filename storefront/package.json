{
  "name": "saleor-storefront",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "next dev --webpack",
    "build": "pnpm run type-check && next build",
    "build:production": "pnpm run type-check && next build",
    "build:skip-type-check": "next build",
    "start": "next start",
    "lint": "eslint .",
    "generate": "graphql-codegen --config .graphqlrc.ts",
    "type-check": "tsc --noEmit",
    "type-check:watch": "tsc --noEmit --watch",
    "prepare": "husky install 2>/dev/null || true"
  },
  "dependencies": {
    "@headlessui/react": "2.2.9",
    "@saleor/auth-sdk": "1.0.3",
    "@urql/core": "6.0.1",
    "@stripe/react-stripe-js": "3.7.0",
    "@stripe/stripe-js": "7.3.0",
    "clsx": "2.1.0",
    "editorjs-html": "3.4.3",
    "swiper": "^12.0.0",
    "formik": "2.4.5",
    "libphonenumber-js": "1.10.58",
    "lodash-es": "4.17.21",
    "lucide-react": "0.358.0",
    "next": "16.1.6",
    "query-string": "8.1.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-error-boundary": "4.0.13",
    "react-slider": "2.0.6",
    "react-spinners": "0.13.8",
    "react-toastify": "11.0.5",
    "sharp": "0.34.5",
    "ts-invariant": "0.10.3",
    "url-join": "5.0.0",
    "urql": "5.0.1",
    "vaul": "^1.1.2",
    "xss": "1.0.15",
    "yup": "1.3.2",
    "zod": "^3.23.8",
    "use-sync-external-store": "1.4.0",
    "zustand": "5.0.11"
  },
  "pnpm": {
    "overrides": {
      "dompurify@<3.2.4": ">=3.2.4",
      "js-yaml@>=4.0.0 <4.1.1": ">=4.1.1",
      "js-yaml@<3.14.2": ">=3.14.2",
      "vite@>=6.0.0 <6.4.1": ">=6.4.1",
      "ws@>=8.0.0 <8.17.1": ">=8.17.1"
    }
  },
  "devDependencies": {
    "@graphql-codegen/cli": "5.0.0",
    "@graphql-codegen/client-preset": "4.1.0",
    "@graphql-typed-document-node/core": "3.2.0",
